{
  "name": "shopmaster-desktop",
  "version": "1.0.0",
  "description": "ShopMaster POS - Desktop App",
  "author": "ShopMaster",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "start:dev": "cross-env NODE_ENV=development electron .",
    "build:web": "cd ../mobile && npx expo export --platform web --output-dir ../desktop/web-build",
    "pack:portable": "node pack-portable.js",
    "pack:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64",
    "pack:win:dir": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir",
    "build": "npm run build:web && npm run pack:portable"
  },
  "build": {
    "appId": "com.shopmaster.desktop",
    "productName": "ShopMaster",
    "copyright": "Copyright 2024 ShopMaster",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "web-build/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "../mobile/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShopMaster"
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
