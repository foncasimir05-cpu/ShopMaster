{
  "name": "shopmaster-desktop",
  "version": "1.0.0",
  "description": "ShopMaster POS — Desktop App",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "start:dev": "cross-env NODE_ENV=development electron .",
    "build:web": "cd ../mobile && npx expo export --platform web --output-dir ../desktop/web-build",
    "pack:win": "electron-builder --win --x64",
    "pack:win:dir": "electron-builder --win --dir",
    "build": "npm run build:web && npm run pack:win"
  },
  "build": {
    "appId": "com.shopmaster.desktop",
    "productName": "ShopMaster",
    "copyright": "Copyright © 2024 ShopMaster",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "web-build/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "../mobile/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "../mobile/assets/icon.png",
      "uninstallerIcon": "../mobile/assets/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShopMaster"
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  }
}
