{
  "name": "shopmaster",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "mobile",
    "shared"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:mobile": "npm run start --workspace=mobile",
    "desktop:install": "cd desktop && npm install",
    "desktop:build": "cd desktop && npm run build",
    "desktop:start": "cd desktop && npm start",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" --ignore-path .eslintignore",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-native": "^4.1.0",
    "prettier": "^3.2.5"
  }
}
